OPENCLAW_TELEGRAM_BOT_TOKEN=
OPENCLAW_TELEGRAM_ALLOWED_CHAT_IDS=
OPENCLAW_CRON_CHAT_IDS=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_RUNTIME_LABEL=DGX Spark

# Docker Compose profile isolation. Keep these defaults for the classic single
# profile layout, or point them at profiles/<name>/... for personal/demo splits.
OPENCLAW_ENV_FILE=.env
OPENCLAW_HOST_WORKSPACE=./workspace
OPENCLAW_HOST_GATEWAY_DATA=./gateway-data

OPENCLAW_VLLM_MODEL=Qwen/Qwen3.6-27B-FP8
OPENCLAW_GPU_MEMORY_UTILIZATION=0.70
OPENCLAW_MAX_MODEL_LEN=262144
OPENCLAW_MAX_NUM_SEQS=4
HF_CACHE_DIR=./.cache/huggingface

OPENCLAW_SYSTEM_PROMPT=You are OpenClaw, a local-first personal AI assistant running on the user's Arm Continuum local runtime. Answer clearly, practically, and do not reveal hidden reasoning.
OPENCLAW_MAX_REPLY_CHARS=3500
OPENCLAW_MAX_TOKENS=160
OPENCLAW_REQUEST_TIMEOUT=150
OPENCLAW_POLL_TIMEOUT=30

OPENCLAW_WEB_ENABLED=true
OPENCLAW_WEB_TIMEOUT=20
OPENCLAW_SCRAPER_BASE_URL=http://openclaw-browser-scraper:8787
OPENCLAW_SCRAPER_LIMIT=3
OPENCLAW_WEB_CONTEXT_CHARS=6000

OPENCLAW_VISION_ENABLED=true
OPENCLAW_VISION_MAX_TOKENS=500

OPENCLAW_WHISPER_ENABLED=true
OPENCLAW_WHISPER_BASE_URL=http://openclaw-whisper:8765
OPENCLAW_WHISPER_TIMEOUT=180
OPENCLAW_WHISPER_MODEL=base

OPENCLAW_MEMORY_ENABLED=true
OPENCLAW_OLLAMA_BASE_URL=http://host.docker.internal:11434
OPENCLAW_EMBEDDING_MODEL=nomic-embed-text:latest
OPENCLAW_EMBEDDING_VECTOR_SIZE=768
OPENCLAW_QDRANT_BASE_URL=http://host.docker.internal:6333
OPENCLAW_TRACKER_COLLECTION=personal_tracker_memory
OPENCLAW_KNOWLEDGE_COLLECTION=personal_knowledge_base
OPENCLAW_RETRIEVAL_LIMIT=5
OPENCLAW_INBOX_PATH=/workspace/inbox
OPENCLAW_WATCHER_STATE_PATH=/workspace/.openclaw/watcher_state.json
OPENCLAW_WATCHER_POLL_SECONDS=10
OPENCLAW_INGEST_CHUNK_CHARS=1800
OPENCLAW_INGEST_CHUNK_OVERLAP=200

OPENCLAW_CRON_ENABLED=true
OPENCLAW_CRON_TIMEZONE=Europe/London
OPENCLAW_CRON_DAILY_REPORT_TIME=07:00
OPENCLAW_CRON_POLL_SECONDS=30
OPENCLAW_CRON_DUE_WINDOW_MINUTES=15
OPENCLAW_CRON_RUN_ON_START=false
OPENCLAW_CRON_TASKS_CONFIG=/app/cron_tasks.json
OPENCLAW_CRON_JOBS_PATH=/workspace/.openclaw/cron_jobs.json
OPENCLAW_CRON_STATE_PATH=/workspace/.openclaw/cron_state.json
OPENCLAW_TASK_HISTORY_PATH=/workspace/.openclaw/task_history.jsonl

OPENCLAW_GATEWAY_RPC_URL=http://openclaw-gateway:18789/api/v1/admin/rpc
OPENCLAW_GATEWAY_STATE_DB=/gateway-state/openclaw.sqlite
