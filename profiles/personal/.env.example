# OpenClaw personal profile for an Arm CPU-only host such as Radxa Orion O6.
# Copy to profiles/personal/.env and fill in private values.

OPENCLAW_TELEGRAM_BOT_TOKEN=
OPENCLAW_TELEGRAM_ALLOWED_CHAT_IDS=
OPENCLAW_CRON_CHAT_IDS=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_RUNTIME_LABEL=Orion O6 Personal

OPENCLAW_ENV_FILE=profiles/personal/.env
OPENCLAW_HOST_WORKSPACE=./profiles/personal/workspace
OPENCLAW_HOST_GATEWAY_DATA=./profiles/personal/gateway-data

OPENCLAW_VLLM_BASE_URL=http://127.0.0.1:8080/v1
OPENCLAW_VLLM_MODEL=ernie-o6
OPENCLAW_SYSTEM_PROMPT=You are OpenClaw, a local-first personal AI assistant running on an Arm CPU-only host. Be concise, practical, and do not reveal hidden reasoning.
OPENCLAW_MAX_REPLY_CHARS=2400
OPENCLAW_MAX_TOKENS=128
OPENCLAW_REQUEST_TIMEOUT=300
OPENCLAW_POLL_TIMEOUT=30

OPENCLAW_DNS_SERVER_1=192.168.0.1
OPENCLAW_DNS_SERVER_2=1.1.1.1

OPENCLAW_WEB_ENABLED=true
OPENCLAW_WEB_TIMEOUT=20
OPENCLAW_SCRAPER_BASE_URL=http://127.0.0.1:8787
OPENCLAW_SCRAPER_LIMIT=2
OPENCLAW_WEB_CONTEXT_CHARS=1800
# Optional fallback for weather questions that do not name a location.
OPENCLAW_DEFAULT_WEATHER_LOCATION=

OPENCLAW_VISION_ENABLED=false
OPENCLAW_VISION_MAX_TOKENS=256

OPENCLAW_WHISPER_ENABLED=true
OPENCLAW_WHISPER_BASE_URL=http://127.0.0.1:8765
OPENCLAW_WHISPER_TIMEOUT=300
OPENCLAW_WHISPER_MODEL=tiny

OPENCLAW_MEMORY_ENABLED=true
OPENCLAW_OLLAMA_BASE_URL=http://127.0.0.1:11434
OPENCLAW_EMBEDDING_MODEL=nomic-embed-text:latest
OPENCLAW_EMBEDDING_VECTOR_SIZE=768
OPENCLAW_QDRANT_BASE_URL=http://127.0.0.1:6333
OPENCLAW_TRACKER_COLLECTION=personal_tracker_memory
OPENCLAW_KNOWLEDGE_COLLECTION=personal_knowledge_base
OPENCLAW_RETRIEVAL_LIMIT=3
OPENCLAW_INBOX_PATH=/workspace/inbox
OPENCLAW_WATCHER_STATE_PATH=/workspace/.openclaw/watcher_state.json
OPENCLAW_WATCHER_POLL_SECONDS=15
OPENCLAW_INGEST_CHUNK_CHARS=1200
OPENCLAW_INGEST_CHUNK_OVERLAP=120

OPENCLAW_CRON_ENABLED=true
# Use an IANA timezone such as Europe/London, America/New_York, or Asia/Singapore.
OPENCLAW_CRON_TIMEZONE=UTC
OPENCLAW_CRON_DAILY_REPORT_TIME=07:00
OPENCLAW_CRON_POLL_SECONDS=30
OPENCLAW_CRON_DUE_WINDOW_MINUTES=15
OPENCLAW_CRON_RUN_ON_START=false
OPENCLAW_CRON_TASKS_CONFIG=/app/cron_tasks.json
OPENCLAW_CRON_JOBS_PATH=/workspace/.openclaw/cron_jobs.json
OPENCLAW_CRON_STATE_PATH=/workspace/.openclaw/cron_state.json
OPENCLAW_TASK_HISTORY_PATH=/workspace/.openclaw/task_history.jsonl

OPENCLAW_GATEWAY_RPC_URL=http://127.0.0.1:18789/api/v1/admin/rpc
OPENCLAW_GATEWAY_STATE_DB=/gateway-state/openclaw.sqlite
